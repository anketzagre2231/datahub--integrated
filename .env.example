# ──────────────────────────────────────────────────
# LOCAL DEVELOPMENT
# ──────────────────────────────────────────────────

# Frontend API base URL
# For local split development set to http://localhost:5000
# ⚠️ Do NOT set this on Vercel — leave it blank/unset so the frontend
#    automatically calls the serverless backend at /api/backend
NEXT_PUBLIC_API_URL=http://localhost:5000

# Application URL (used for OAuth redirects)
# For local development:
APP_URL=http://localhost:3000

# ──────────────────────────────────────────────────
# QuickBooks Configuration (required everywhere)
# ──────────────────────────────────────────────────

QB_REALM_ID=
QB_ACCESS_TOKEN=
QB_REFRESH_TOKEN=
QB_BASIC_TOKEN=
QB_BASE_URL=https://sandbox-quickbooks.api.intuit.com
QB_CLIENT_ID=
QB_CLIENT_SECRET=

# ──────────────────────────────────────────────────
# OAuth Redirect URI
# ──────────────────────────────────────────────────
# For local dev with separate backend:
QB_REDIRECT_URI=http://localhost:5000/api/auth/callback

# ⚠️ On Vercel: either REMOVE this variable entirely (recommended)
#    so the app auto-detects the production URL, or set it to:
#    https://your-app.vercel.app/api/backend/api/auth/callback
# ⚠️ You MUST also add this same URL to your Intuit Developer Portal
#    under Keys & OAuth → Redirect URIs

# ──────────────────────────────────────────────────
# Server Configuration (local only — not needed on Vercel)
# ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
API_URL=http://localhost:5000
