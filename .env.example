# Frontend
# Leave blank in Vercel when deploying frontend + backend together in one project.
# For local split development, set this to http://localhost:5000
NEXT_PUBLIC_API_URL=

# Application URL
# Set this in Vercel to your production domain, for example:
# APP_URL=https://your-app.vercel.app
APP_URL=

# Backend / QuickBooks
QB_REALM_ID=
QB_ACCESS_TOKEN=
QB_BASE_URL=https://sandbox-quickbooks.api.intuit.com
QB_REFRESH_TOKEN=
QB_BASIC_TOKEN=
QB_CLIENT_ID=
QB_CLIENT_SECRET=

# Optional local-only callback override
QB_REDIRECT_URI=

# Server Configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
API_URL=http://localhost:5000
